---
const title = 'Chat - schema.org Agent';
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>💬</text></svg>" />
  <script src="https://cdn.jsdelivr.net/npm/fabric@7/dist/fabric.min.js"></script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg-dark: #0d1117;
      --bg-card: #161b22;
      --border: #30363d;
      --text: #e6edf3;
      --text-muted: #8b949e;
      --accent: #58a6ff;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      background: var(--bg-dark);
      color: var(--text);
      height: 100vh;
    }
    #app { display: flex; height: 100vh; }
    
    /* Sidebar */
    #sidebar {
      width: 280px;
      background: var(--bg-card);
      border-right: 1px solid var(--border);
      padding: 1rem;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    #sidebar h3 { font-size: 0.875rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
    
    .type-item {
      padding: 0.5rem 0.75rem;
      margin: 0.25rem 0;
      background: var(--bg-dark);
      border: 1px solid var(--border);
      border-radius: 6px;
      cursor: grab;
      font-size: 0.875rem;
      transition: all 0.2s;
    }
    .type-item:hover { border-color: var(--accent); background: var(--accent); color: var(--bg-dark); }
    
    .tools { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .tool-btn {
      padding: 0.5rem 0.75rem;
      font-size: 0.75rem;
      background: var(--bg-dark);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text-muted);
      cursor: pointer;
      transition: all 0.2s;
    }
    .tool-btn:hover { border-color: var(--accent); color: var(--text); }
    
    /* Main */
    #main { flex: 1; display: flex; flex-direction: column; }
    
    #chat-container {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }
    
    #messages {
      flex: 1;
      overflow-y: auto;
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    
    .message {
      max-width: 80%;
      padding: 0.875rem 1rem;
      border-radius: 12px;
      font-size: 0.9375rem;
      line-height: 1.5;
      white-space: pre-wrap;
      animation: fadeIn 0.2s ease;
    }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
    
    .message-user {
      align-self: flex-end;
      background: var(--accent);
      color: var(--bg-dark);
    }
    
    .message-agent {
      align-self: flex-start;
      background: var(--bg-card);
      border: 1px solid var(--border);
    }
    
    .message-agent.streaming::after {
      content: '▋';
      animation: blink 0.6s infinite;
    }
    @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
    
    .source {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-top: 0.5rem;
    }
    .source a { color: var(--accent); text-decoration: none; }
    .source a:hover { text-decoration: underline; }
    
    /* Canvas */
    #canvas-wrapper {
      flex: 1;
      background: #0a0a14;
      position: relative;
      display: none;
    }
    #canvas-wrapper.show { display: block; }
    #canvas-wrapper canvas { width: 100%; height: 100%; }
    
    /* Input */
    #input-bar {
      padding: 1rem;
      background: var(--bg-card);
      border-top: 1px solid var(--border);
      display: flex;
      gap: 0.75rem;
      align-items: center;
    }
    
    #input-bar input {
      flex: 1;
      padding: 0.875rem 1rem;
      font-size: 1rem;
      background: var(--bg-dark);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      outline: none;
    }
    #input-bar input:focus { border-color: var(--accent); }
    
    #input-bar button {
      padding: 0.875rem 1.5rem;
      font-size: 1rem;
      font-weight: 600;
      background: var(--accent);
      color: var(--bg-dark);
      border: none;
      border-radius: 8px;
      cursor: pointer;
    }
    #input-bar button:hover { opacity: 0.9; }
    #input-bar button:disabled { opacity: 0.5; cursor: not-allowed; }
    
    /* Tab toggle */
    .tab-toggle {
      display: flex;
      gap: 0.5rem;
      padding: 0.5rem;
      background: var(--bg-dark);
      border-radius: 8px;
    }
    .tab-btn {
      padding: 0.5rem 1rem;
      font-size: 0.875rem;
      background: none;
      border: none;
      color: var(--text-muted);
      border-radius: 6px;
      cursor: pointer;
    }
    .tab-btn.active { background: var(--bg-card); color: var(--text); }
    
    /* Nav */
    nav { display: flex; gap: 1rem; margin-bottom: 0.5rem; }
    nav a { color: var(--text-muted); text-decoration: none; font-size: 0.875rem; }
    nav a:hover { color: var(--text); }
    nav a.active { color: var(--accent); }
  </style>
</head>
<body>
  <div id="app">
    <div id="sidebar">
      <nav>
        <a href="/">Home</a>
        <a href="/search">Search</a>
      </nav>
      
      <div>
        <h3>📚 Types</h3>
        <div class="type-item" draggable="true" data-type="Thing">Thing</div>
        <div class="type-item" draggable="true" data-type="Person">Person</div>
        <div class="type-item" draggable="true" data-type="Organization">Organization</div>
        <div class="type-item" draggable="true" data-type="Product">Product</div>
        <div class="type-item" draggable="true" data-type="Event">Event</div>
        <div class="type-item" draggable="true" data-type="Place">Place</div>
        <div class="type-item" draggable="true" data-type="CreativeWork">CreativeWork</div>
      </div>
      
      <div>
        <h3>🎨 Canvas Tools</h3>
        <div class="tools">
          <button class="tool-btn" onclick="addRect()">⬜ Box</button>
          <button class="tool-btn" onclick="addCircle()">⭕ Circle</button>
          <button class="tool-btn" onclick="addText('Hello')">📝 Text</button>
          <button class="tool-btn" onclick="clearCanvas()">🗑️ Clear</button>
        </div>
      </div>
    </div>
    
    <div id="main">
      <div class="tab-toggle">
        <button class="tab-btn active" id="chatTab" onclick="showChat()">💬 Chat</button>
        <button class="tab-btn" id="canvasTab" onclick="showCanvas()">🎨 Canvas</button>
      </div>
      
      <div id="chat-container">
        <div id="messages">
          <div class="message message-agent">
            Hi! I'm the schema.org Q&A Agent.
            
I can help you understand schema.org types, properties, and vocabulary.
            
Ask me anything about schema.org!
            
<span class="source">Source: <a href="https://schema.org" target="_blank">schema.org</a></span>
          </div>
        </div>
        
        <div id="canvas-wrapper">
          <canvas id="c"></canvas>
        </div>
        
        <div id="input-bar">
          <input type="text" id="msg" placeholder="Ask about schema.org..." />
          <button id="sendBtn">Send</button>
        </div>
      </div>
    </div>
  </div>
  
  <script>
    // === Chat + Streaming ===
    const messagesDiv = document.getElementById('messages');
    const msgInput = document.getElementById('msg');
    const sendBtn = document.getElementById('sendBtn');
    
    // Simulated streaming response
    const responses = {
      'person': `Person represents a person (alive, dead, undead, or fictional).

Key properties: 
• name
• url  
• jobTitle
• worksFor
• address

<span class="source">Source: <a href="https://schema.org/Person" target="_blank">schema.org/Person</a></span>`,
      'organization': `Organization includes companies, institutions, clubs, etc.

Key properties:
• name
• url
• logo
• contactPoint

<span class="source">Source: <a href="https://schema.org/Organization" target="_blank">schema.org/Organization</a></span>`,
      'creativework': `CreativeWork is the most generic kind of creative work.

Subtypes include:
• Book
• Article  
• Movie
• Image
• MusicRecording

<span class="source">Source: <a href="https://schema.org/CreativeWork" target="_blank">schema.org/CreativeWork</a></span>`,
      'default': `That's a great question about schema.org!

You can explore types at <a href="https://schema.org" target="_blank">schema.org</a>. Key types include:
• Thing (base type)
• Person, Organization, Place
• CreativeWork, Event, Product

<span class="source">Source: <a href="https://schema.org" target="_blank">schema.org</a></span>`
    };
    
    async function streamResponse(text, element) {
      // Simulate streaming (in production, this comes from LLM chunks)
      const words = text.split(' ');
      element.classList.add('streaming');
      
      for (let i = 0; i < words.length; i++) {
        element.textContent += words[i] + ' ';
        messagesDiv.scrollTop = messagesDiv.scrollHeight;
        await new Promise(r => setTimeout(r, 30 + Math.random() * 50));
      }
      
      element.classList.remove('streaming');
    }
    
    async function handleSend() {
      const query = msgInput.value.trim();
      if (!query) return;
      
      // User message
      addMessage(query, 'user');
      msgInput.value = '';
      sendBtn.disabled = true;
      
      // Agent message (streaming)
      const agentMsg = addMessage('', 'agent');
      
      // Find response
      const q = query.toLowerCase();
      let response = responses.default;
      if (q.includes('person')) response = responses.person;
      else if (q.includes('organization') || q.includes('company')) response = responses.organization;
      else if (q.includes('creativework') || q.includes('book') || q.includes('movie')) response = responses.creativework;
      
      await streamResponse(response, agentMsg);
      sendBtn.disabled = false;
      msgInput.focus();
    }
    
    function addMessage(text, role) {
      const div = document.createElement('div');
      div.className = `message message-${role}`;
      div.textContent = text;
      messagesDiv.appendChild(div);
      messagesDiv.scrollTop = messagesDiv.scrollHeight;
      return div;
    }
    
    sendBtn.addEventListener('click', handleSend);
    msgInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') handleSend();
    });
    
    // === Canvas (Fabric.js) ===
    let canvas;
    function initCanvas() {
      canvas = new fabric.Canvas('c');
      const wrapper = document.getElementById('canvas-wrapper');
      canvas.setDimensions({ width: wrapper.clientWidth, height: wrapper.clientHeight });
    }
    
    function showCanvas() {
      document.getElementById('chatTab').classList.remove('active');
      document.getElementById('canvasTab').classList.add('active');
      document.getElementById('messages').style.display = 'none';
      document.getElementById('canvas-wrapper').classList.add('show');
      if (!canvas) initCanvas();
    }
    
    function showChat() {
      document.getElementById('chatTab').classList.add('active');
      document.getElementById('canvasTab').classList.remove('active');
      document.getElementById('messages').style.display = 'flex';
      document.getElementById('canvas-wrapper').classList.remove('show');
    }
    
    window.addRect = () => {
      if (!canvas) initCanvas();
      canvas.add(new fabric.Rect({ left: 100, top: 100, fill: '#58a6ff', width: 80, height: 80 }));
    };
    
    window.addCircle = () => {
      if (!canvas) initCanvas();
      canvas.add(new fabric.Circle({ left: 100, top: 100, fill: '#6e40c9', radius: 50 }));
    };
    
    window.addText = (text) => {
      if (!canvas) initCanvas();
      canvas.add(new fabric.Text(text, { left: 100, top: 100, fill: '#e6edf3', fontSize: 24 }));
    };
    
    window.clearCanvas = () => {
      if (canvas) canvas.clear();
    };
    
    // Drag from sidebar
    document.querySelectorAll('.type-item').forEach(item => {
      item.addEventListener('dragstart', (e) => {
        e.dataTransfer.setData('text/plain', item.dataset.type);
      });
    });
  </script>
</body>
</html>
